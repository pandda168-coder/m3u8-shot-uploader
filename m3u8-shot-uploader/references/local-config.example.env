# Local operations config for private runtime use only.
# Copy to .env.local or .env in the skill root and keep it out of git.

COMMON_API_BASE_URL=https://your-private-api.example.com/api/web
WEB_ORIGIN=https://your-private-api.example.com

# Optional route used when you want to construct the playable m3u8 URL from a relative path.
M3U8_API_ROUTE=/admin/vid/m3u8
M3U8_URL_QUERY=

UPLOAD_API_ROUTE=/admin/vid/uploadStaticBatch
UPLOAD_COOKIE=your_private_upload_cookie_here
UPLOAD_REFERER=
UPLOAD_ORIGIN=
UPLOAD_FIELD_NAME=upload[]
REQUEST_TIMEOUT=120

UPDATE_API_ROUTE=/admin/vid/upload/screenshots
UPDATE_API_METHOD=POST
UPDATE_CONTENT_TYPE=application/json
UPDATE_COOKIE=your_private_update_cookie_here
UPDATE_REFERER=
UPDATE_ORIGIN=
UPDATE_M3U8_URL_FIELD=m3u8Url
UPDATE_SCREENSHOTS_FIELD=screenshots
UPDATE_M3U8_VALUE=relative_path
UPDATE_BODY_TEMPLATE=

# Optional direct overrides
UPLOAD_API_URL=
UPDATE_API_URL=
